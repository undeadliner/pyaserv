{
  "name": "@pyaserv/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "PyaServ API — Cloudflare Worker. Consumes @pya-platform/auth for sessions/OAuth/passkeys and serves listings + inquiries.",
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run --outdir dist",
    "deploy": "wrangler deploy",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@pya-platform/auth": "*",
    "@pya-platform/shared": "*",
    "hono": "^4.6.0",
    "valibot": "^1.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240909.0",
    "typescript": "^5.7.2",
    "wrangler": "^4.0.0"
  }
}
