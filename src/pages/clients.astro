---
import Base from '~/layouts/Base.astro'

interface JobRequest {
  readonly poster: string
  readonly title: string
  readonly description: string
  readonly initial: string
  readonly barrio: string
  readonly budgetGs: number
  readonly tags: ReadonlyArray<string>
  readonly posted: string
}

const samples: ReadonlyArray<JobRequest> = [
  {
    poster: 'Ana V.',
    title: 'Necesito reparar una llave térmica que salta',
    description: 'Salta cada vez que enchufo la heladera nueva. Casa de una planta en Villa Morra. Esta semana si se puede.',
    initial: 'A',
    barrio: 'Villa Morra',
    budgetGs: 200000,
    tags: ['Electricidad', 'Urgencia'],
    posted: 'hace 2 h',
  },
  {
    poster: 'Pedro G.',
    title: 'Traducción de título universitario al inglés con apostille',
    description: 'Para una maestría en España. Necesito el original traducido y certificado en menos de 10 días.',
    initial: 'P',
    barrio: 'Recoleta',
    budgetGs: 350000,
    tags: ['Idiomas', 'Documentos'],
    posted: 'hace 5 h',
  },
  {
    poster: 'Camila R.',
    title: 'Logo + carta para mi nueva cafetería',
    description: 'Abro en septiembre, necesito identidad simple, cálida, papelería de menú y redes para el lanzamiento.',
    initial: 'C',
    barrio: 'Carmelitas',
    budgetGs: 1500000,
    tags: ['Diseño', 'Marketing'],
    posted: 'ayer',
  },
  {
    poster: 'Roberto T.',
    title: 'Profe de matemática para mi hija — bachillerato',
    description: 'Le cuesta funciones y trigonometría. Una clase por semana, presencial o online. Empezamos cuando puedas.',
    initial: 'R',
    barrio: 'Las Mercedes',
    budgetGs: 80000,
    tags: ['Educación'],
    posted: 'ayer',
  },
  {
    poster: 'Marta E.',
    title: 'Pelo y maquillaje para una boda — 5 personas',
    description: 'Sábado 12. Necesito a alguien que venga al hotel temprano. Novia + 4 madrinas.',
    initial: 'M',
    barrio: 'Manorá',
    budgetGs: 1200000,
    tags: ['Peluquería', 'Evento'],
    posted: 'hace 2 días',
  },
  {
    poster: 'Sergio D.',
    title: 'Fuga de gas en el calefón',
    description: 'Olor fuerte en la cocina, ya cerré la llave. Necesito a alguien hoy o mañana temprano.',
    initial: 'S',
    barrio: 'Asunción centro',
    budgetGs: 300000,
    tags: ['Plomería', 'Gas', 'Urgencia'],
    posted: 'hace 30 min',
  },
]

const fmtGs = (n: number): string => `${n.toLocaleString('es-PY')} Gs`
---
<Base
  title="Pedidos de trabajo en Paraguay"
  description="Clientes en Paraguay que buscan a un profesional. Si ofrecés ese servicio, contactá directo."
  active="clients"
>
  <section class="ps-hero">
    <h1>Pedidos de trabajo</h1>
    <p>Lo que la gente está buscando ahora. Si podés resolverlo, escribí directo al cliente.</p>
  </section>

  <form class="ps-filter-bar" role="search" aria-label="Filtrar pedidos">
    <input type="search" name="q" placeholder="Buscar por palabra clave…" autocomplete="off" />
    <select name="category" aria-label="Categoría">
      <option value="">Todas las categorías</option>
      <option>Electricidad</option>
      <option>Plomería</option>
      <option>Idiomas</option>
      <option>Diseño</option>
      <option>Educación</option>
      <option>Peluquería</option>
      <option>Marketing</option>
    </select>
    <select name="urgency" aria-label="Urgencia">
      <option value="">Todas las urgencias</option>
      <option value="urgent">Urgente (hoy / mañana)</option>
      <option value="week">Esta semana</option>
      <option value="flex">Flexible</option>
    </select>
  </form>

  <section class="ps-list" aria-label="Pedidos de trabajo">
    {samples.map((r) => (
      <article class="ps-listing ps-listing--request">
        <header class="ps-listing__head">
          <span class="ps-listing__avatar" aria-hidden="true">{r.initial}</span>
          <div>
            <div class="ps-listing__name">{r.poster}</div>
            <div class="ps-listing__meta">{r.barrio} · Presupuesto {fmtGs(r.budgetGs)} · {r.posted}</div>
          </div>
        </header>
        <h2 class="ps-listing__title">{r.title}</h2>
        <p class="ps-listing__body">{r.description}</p>
        <div class="ps-listing__tags">
          {r.tags.map((t) => <span class="ps-tag">{t}</span>)}
        </div>
      </article>
    ))}
  </section>

  <p class="ps-banner">
    ¿Necesitás algo? Cuando habiliten las cuentas vas a poder publicar tu pedido en menos de un minuto y
    recibir respuestas directo en el chat. Por ahora, comentá en el GitHub del proyecto si te interesa.
  </p>
</Base>
