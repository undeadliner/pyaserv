---
import '~/styles/global.css'

interface Props {
  readonly title: string
  readonly description?: string
  readonly active?: 'home' | 'specialists' | 'clients'
}

const { title, description, active = 'home' } = Astro.props
const base = import.meta.env.BASE_URL.replace(/\/$/, '')
const href = (path: string): string => `${base}${path}`
---
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} · PyaServ</title>
    {description !== undefined && <meta name="description" content={description} />}
    <link rel="icon" type="image/svg+xml" href={href('/favicon.svg')} />
  </head>
  <body>
    <header class="ps-topbar">
      <a href={href('/')} class="ps-topbar__brand">
        <span class="ps-topbar__brand-em">Pya</span>Serv
      </a>
      <nav class="ps-topbar__nav" aria-label="Principal">
        <a href={href('/specialists/')} aria-current={active === 'specialists' ? 'page' : undefined}>Profesionales</a>
        <a href={href('/clients/')} aria-current={active === 'clients' ? 'page' : undefined}>Pedidos</a>
      </nav>
    </header>
    <main class="ps-shell">
      <slot />
    </main>
    <footer class="ps-foot">
      © PyaServ · construido sobre <a href="https://github.com/undeadliner/pya-platform">pya-platform</a> ·
      hermano de <a href="https://pyaeats.com">PyaEats</a>
    </footer>
  </body>
</html>
