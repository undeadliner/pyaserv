{
  "name": "pyaserv",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "PyaServ — services classifieds for Paraguay. Two-sided marketplace built on pya-platform.",
  "packageManager": "bun@1.2.0",
  "workspaces": ["apps/*"],
  "scripts": {
    "setup": "bun scripts/setup.ts",
    "dev:site": "bun --filter @pyaserv/site dev",
    "dev:api": "bun --filter @pyaserv/api dev",
    "build:site": "bun --filter @pyaserv/site build",
    "build:api": "bun --filter @pyaserv/api build",
    "type-check": "bun --filter '*' type-check"
  },
  "//pya-platform-overrides": "@undeadliner/pya-* resolved from sibling pya-platform checkout. Same pattern as pyaeats-app.",
  "overrides": {
    "@undeadliner/pya-shared": "file:../pya-platform/packages/shared",
    "@undeadliner/pya-auth": "file:../pya-platform/packages/auth"
  }
}
